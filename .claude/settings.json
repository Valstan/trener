{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git branch:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git pull --ff-only:*)",
      "Bash(git push -u origin feat/*)",
      "Bash(git push -u origin fix/*)",
      "Bash(git push -u origin chore/*)",
      "Bash(git push -u origin docs/*)",
      "Bash(git push -u origin refactor/*)",
      "Bash(git push origin feat/*)",
      "Bash(git push origin fix/*)",
      "Bash(git push origin chore/*)",
      "Bash(git push origin docs/*)",
      "Bash(git push origin refactor/*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(corepack pnpm -C web typecheck:*)",
      "Bash(corepack pnpm -C web lint:*)",
      "Bash(corepack pnpm -C web build:*)",
      "Bash(corepack pnpm -C web test:*)",
      "Bash(corepack pnpm -C web deadcode:*)",
      "Bash(corepack pnpm -C web install:*)",
      "Bash(corepack pnpm -C web generate:types:*)",
      "Bash(corepack pnpm -C web generate:importmap:*)",
      "Bash(corepack pnpm -C web migrate:status:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push -fu:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push origin main:*)",
      "Bash(git push origin master:*)",
      "Bash(git push -u origin main:*)",
      "Bash(git push -u origin master:*)",
      "Bash(git push origin HEAD:*)",
      "Bash(git push -u origin HEAD:*)",
      "Bash(gh workflow run deploy-prod:*)",
      "Bash(gh workflow run deploy:*)"
    ]
  }
}
