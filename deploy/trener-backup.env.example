# Шаблон конфига offsite-бэкапа. Реальный файл — /etc/trener/trener-backup.env
# (root:valstan, chmod 0640, вне репо — #008). Скопировать и заполнить на боксе.

# Роль с правом дампа БД (app-роль годится; можно завести выделенную read-only backup-роль).
BACKUP_DATABASE_URL=postgresql://USER:PASS@127.0.0.1:5432/trener

# Публичный gpg-ключ владельца (ASCII-armored, .asc). Приватный ключ — ВНЕ бокса (у владельца)!
BACKUP_GPG_RECIPIENT_FILE=/etc/trener/backup-pubkey.asc

# Каталог локальных шифрованных дампов (буфер для push / источник для pull).
BACKUP_WORKDIR=/home/valstan/trener/backups

# Сколько дней хранить (локально и в remote).
BACKUP_RETENTION_DAYS=30

# PUSH-модель (опционально): rclone-remote в RF S3 (Yandex/Selectel/VK/Timeweb — любой RF S3).
# Пусто → PULL-модель: дамп лежит в WORKDIR, его тянет домашняя машина по расписанию.
# Пример: BACKUP_RCLONE_REMOTE=trener-backup:my-bucket/trener
BACKUP_RCLONE_REMOTE=
