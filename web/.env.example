# ─────────────────────────────────────────────────────────────────────────────
# trener — пример переменных окружения.
#
# ⚠️ Это ШАБЛОН. Реальные значения НЕ коммитим (pool #008 «секреты вне репо»).
#   • Локально:  скопировать в web/.env и подставить значения (web/.env в .gitignore).
#   • На проде:  секреты живут в /etc/trener/trener.env (root:0640) и подключаются
#                systemd-юнитом через EnvironmentFile=, НЕ в дереве репо.
#
# ⚠️ 152-ФЗ (ст.18 ч.5): прод-БД ОБЯЗАНА быть в РФ — первая запись данных РФ-граждан
#   ложится в РФ-локализованную БД. DATABASE_URL на проде указывает на РФ-хостинг.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL. Локально (Windows + системный Postgres): postgres/postgres.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/trener

# Payload auth secret (шифрует JWT). На проде — длинная случайная строка.
PAYLOAD_SECRET=generate_a_long_random_secret_here

# Публичный URL сервера (без хвостового слэша).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ─── Web-push (M2-PR8) — best-effort пуш об изменениях ───────────────────────
# Одна VAPID-пара покрывает iOS (16.4+, только установленное PWA) и Android/Chrome
# (kickoff §2; legacy FCM server-key не используем). Сгенерировать локально:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Публичный ключ уходит в клиент (NEXT_PUBLIC_*), приватный — серверный секрет
# (#008: на проде в /etc/trener/trener.env). Пусто → пуш отключён (фан-аут ставит
# pushResult=skipped), in-app очередь/ack работают как обычно. Реальная доставка
# iOS/Android требует HTTPS (M3).
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@trener.example.ru

# ─── SMTP-relay (magic-link онбординг — PR2; уведомления) ────────────────────
# Провайдеро-независимо: любой внешний relay (Resend / Brevo / SendGrid / …).
# Пока SMTP_HOST пуст — email-адаптер в payload.config НЕ подключается, письма
# пишутся в консоль (WARN «No email adapter»); сборка/типы при этом зелёные.
# Реальные SMTP-доступы — ТОЛЬКО в /etc/trener/trener.env на проде (#008).
#   port 465 → secure=true (implicit TLS), 587/2525 → secure=false (STARTTLS).
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=your_relay_api_key_or_password
# SMTP_FROM_ADDRESS=no-reply@trener.example.ru
# SMTP_FROM_NAME=Футбольная школа
# SMTP_SECURE=false
